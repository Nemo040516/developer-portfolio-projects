{
  "name": "wms-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "e2e:install": "playwright install chromium",
    "e2e:test": "playwright test -c e2e/playwright.config.ts",
    "e2e:test:smoke": "playwright test -c e2e/playwright.config.ts e2e/tests/smoke",
    "e2e:test:core": "playwright test -c e2e/playwright.config.ts e2e/tests/m1-m6",
    "e2e:test:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "e2e:test:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "element-plus": "^2.10.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "dotenv": "^17.3.1",
    "vite": "^6.2.2"
  }
}
